VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
VITE_AUTH0_AUDIENCE=https://projgestao-pf/api
VITE_API_URL=http://localhost:3000

# Optional — only set if you used a different namespace in the Auth0 Action.
# Defaults: https://projgestao-pf/roles and https://projgestao-pf/email
# VITE_AUTH0_ROLES_CLAIM=https://projgestao-pf/roles
# VITE_AUTH0_EMAIL_CLAIM=https://projgestao-pf/email
